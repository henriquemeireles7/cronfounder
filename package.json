{
  "name": "cronfounder",
  "version": "0.1.0",
  "description": "A company harness: the structured environment an agent mounts to run and grow a business. Sensors write reality, a journal remembers, gates protect your principal, and growth becomes a loop.",
  "keywords": [
    "agents",
    "a2a",
    "company-as-code",
    "growth",
    "autonomous-agents",
    "claude-code",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquemeireles7/cronfounder.git"
  },
  "homepage": "https://github.com/henriquemeireles7/cronfounder#readme",
  "type": "module",
  "bin": {
    "cronfounder": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "site",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
