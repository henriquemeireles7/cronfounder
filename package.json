{
  "name": "cronfounder",
  "version": "0.2.0",
  "description": "A company harness: the structured environment an agent mounts to run and grow a business. Sensors write reality, a journal remembers, gates protect your principal, and growth becomes a loop.",
  "keywords": [
    "agents",
    "a2a",
    "company-as-code",
    "growth",
    "autonomous-agents",
    "claude-code",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquemeireles7/cronfounder.git"
  },
  "homepage": "https://github.com/henriquemeireles7/cronfounder#readme",
  "type": "module",
  "bin": {
    "cronfounder": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "!docs/.vitepress",
    "site",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "npm run build",
    "sim": "npm run build && node scripts/sim.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^7.0.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.13.3",
    "vitest": "^3.1.0"
  }
}
